# Схема задач для CLI task-tracker (нотация системы типов — essensio/notation).
# Запуск: npm run tasks
Приоритет = Строка & _ ~ ["низкий", "средний", "высокий"]
Статус    = Строка & _ ~ ["todo", "в работе", "готово"]
Название  = Строка & len(_) >= 1 and len(_) <= 80
Задача    = {#, название: Название, приоритет: Приоритет, статус: Статус}
